{
  "name": "moorhen-wrapper",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "package": "electron-forge package",
    "make": "electron-forge make"
  },
  "config": {
    "forge": {
      "packagerConfig": {
        "name": "MoorhenLocal"
      },
      "makers": [
        { "name": "@electron-forge/maker-zip", "platforms": ["darwin"] }
      ]
    }
  },
  "devDependencies": {
    "electron": "^38.0.0",
    "@electron-forge/cli": "^7.0.0",
    "@electron-forge/maker-zip": "^7.0.0"
  }
}
